<%- include('includes/head')%>
    <%- include('includes/nav')%>

        <div class="container">
            <div class="text-center py-4">
                <h1>Criar conta ou Entrar</h1>
                <p class="text-center lead">Faça login ou crie sua conta abaixo</p>
            </div>

            <%- include('includes/messages'); %>
                <div class="row g-4">
                    <div class="col-lg-6">
                        <div class="p-4 shadow rounded-4">
                            <h4>Faça seu cadastro</h4>
                            <p>Se você ainda não tem conta, preencha o formulário abaixo:</p>
                            <form class="form-cadastro" action="/login/register" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <div class="mb-3 form-group">
                                    <label for="exampleInputEmail1" class="form-label">Seu E-mail</label>
                                    <input type="email" class="form-control" name="email" aria-describedby="emailHelp">
                                </div>
                                <div class="mb-3 form-group">
                                    <label for="exampleInputPassword1" class="form-label">Sua senha</label>
                                    <input type="password" class="form-control" name="password">
                                </div>

                                <button type="submit" class="btn btn-ed">Criar minha conta</button>
                            </form>
                        </div>
                    </div>

                    <div class="col-lg-6">

                        <div class=" p-4 shadow rounded-4">
                            <h4>Faça seu login</h4>
                            <p>Se você já tem uma conta, faça login abaixo:</p>
                            <form class="form-login" action="/login/login" method="POST">
                                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <div class="mb-3 form-group">
                                    <label for="exampleInputEmail1" class="form-label">Seu E-mail</label>
                                    <input type="email" class="form-control" name="email" aria-describedby="emailHelp">
                                </div>
                                <div class="mb-3 form-group">
                                    <label for="exampleInputPassword1" class="form-label">Sua senha</label>
                                    <input type="password" class="form-control" name="password">
                                </div>

                                <button type="submit" class="btn btn-ed">Entrar</button>
                            </form>
                        </div>
                    </div>
                </div>

        </div>

        <%- include('includes/footer')%>