<%- include('includes/head')%>
    <%- include('includes/nav')%>

        <div class="container">
            <div class="row">
                <div class="col-lg-2"></div>

                <div class="col-lg-8 my-3">
                    <h1 class="text-center">Contato</h1>

                    <%- include('includes/messages') %>

                        <% if(contato._id) { %>
                            <p class="text-center lead">Edite seu contato abaixo</p>

                            <form class="form-contato p-4 shadow rounded-4" action="/contato/edit/<%= contato._id %>"
                                method="POST">
                                <% } else{ %>
                                    <p class="text-center lead">Crie seu contato abaixo</p>

                                    <form class="form-contato p-4 shadow rounded-4" action="/contato/register"
                                        method="POST">
                                        <% }%>
                                            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                            <div class="mb-3 form-group">
                                                <label for="" class="form-label validar">Nome</label>
                                                <input value="<%= contato.nome %>" type="text" class="form-control"
                                                    name="nome">
                                            </div>

                                            <div class="mb-3 form-group">
                                                <label for="" class="form-label validar">Sobrenome</label>
                                                <input value="<%= contato.sobrenome %>" type="text" class="form-control"
                                                    name="sobrenome">
                                            </div>

                                            <div class="mb-3 form-group">
                                                <label for="" class="form-label validar">Email</label>
                                                <input value="<%= contato.email %>" type="email" class="form-control"
                                                    name="email">
                                </div>

                                            <div class="mb-3 form-group">
                                                <label for="" class="form-label validar">Telefone</label>
                                                <input value="<%= contato.telefone %>" type="tel" class="form-control"
                                                    name="telefone">
                                            </div>


                                            <div class="text-end">
                                                <a class="btn btn-secondary me-1" href="/">Voltar</a>
                                                <button type="submit" class="btn btn-ed">Salvar</button>
                                            </div>

                                    </form>
                            </form>
                <div class="col-lg-2"></div>

                </div>

            </div>
        </div>

        <%- include('includes/footer')%>